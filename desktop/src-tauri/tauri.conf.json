{
  "package": {
    "productName": "Extract",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "cd ../.. && pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build",
    "devPath": "http://localhost:5173",
    "distDir": "../../web/dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": { "all": true },
      "fs": {
        "all": true,
        "scope": ["$HOME/**", "$DOWNLOAD/**", "$DESKTOP/**", "$DOCUMENT/**"]
      },
      "dialog": { "all": true },
      "path": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.extract.app",
      "icon": [],
      "macOS": {
        "minimumSystemVersion": "11.0"
      }
    },
    "security": {
      "csp": "default-src 'self' http://localhost:8000 blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    },
    "windows": [
      {
        "title": "Extract",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "fileDropEnabled": true
      }
    ]
  }
}
