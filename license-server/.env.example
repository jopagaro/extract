# Copy this to .env and fill in your values
# Never commit .env to git

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Long random string — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
LICENSE_HMAC_SECRET=change_me_to_a_long_random_string

# SMTP for sending license key emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@yourdomain.com

# Links shown in the license email
DOWNLOAD_URL_MAC=https://yourdomain.com/downloads/Extract-mac.dmg
DOWNLOAD_URL_WIN=https://yourdomain.com/downloads/Extract-win.exe

# Max machines per license (default 3)
MAX_ACTIVATIONS=3

# SQLite DB path (Railway: use /data/licenses.db for persistent volume)
DB_PATH=licenses.db
